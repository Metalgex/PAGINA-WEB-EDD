/* ss+ 2025-12-04 14:08:36*/ window.ssm_config = {"scriptBuildDate":"2025-12-04 14:08:36","targetingKey":"53_flatico","run_condition":"navigator.userAgent.indexOf('ghost-inspector') === -1 &&\r\nwindow.location.href.indexOf(\"www.flaticon.es\/resultados?word=juguetes%20sexuales\")==-1","gdpr_check":true,"targeting":{},"amazon_pubid":"d2c1d4de-7c69-49c2-8aec-7ee14abe5ed5","prebid_timeout":900,"refresh_on_change_url":true,"max_refresh_session":999,"eval_script":"\/*(function ssmInitSlotRefreshWatcher(ssmIntervalSeconds = 15, ssmRefreshThresholdSeconds = 1) {\r\n  \r\n  ssmSmartTag.log(\"[SSM BOOST]=>ON\");\r\n  if (!window.ssmAdSlotTime) window.ssmAdSlotTime = {};\r\n  if (!window.ssmAdSlotLineItem) window.ssmAdSlotLineItem = {}; \/\/ guardamos el \u00faltimo lineItemId\r\n\r\n  const ssmNow = () => Date.now();\r\n\r\n  googletag.cmd.push(() => {\r\n    \/\/ Evento cuando un slot termina de renderizar\r\n    googletag.pubads().addEventListener('slotRenderEnded', (ssmEvent) => {\r\n      const ssmRenderedId = ssmEvent.slot.getSlotElementId();\r\n      window.ssmAdSlotTime[ssmRenderedId] = ssmNow();\r\n      window.ssmAdSlotLineItem[ssmRenderedId] = ssmEvent.lineItemId; \/\/ guardamos el lineItemId\r\n\r\n      if (ssmEvent.lineItemId === 7002356118) {\r\n        const ssmTargeting = ssmEvent.slot.getTargeting('ssmBoost');\r\n        if (ssmTargeting.includes('true')) {\r\n          ssmEvent.slot.clearTargeting('up_recovery');\r\n        }\r\n      }\r\n    });\r\n  });\r\n\r\n  \/\/ Verifica si un elemento est\u00e1 visible en el viewport\r\n  function ssmIsInViewport(ssmElement) {\r\n    const ssmRect = ssmElement.getBoundingClientRect();\r\n    return (\r\n      ssmRect.top < window.innerHeight &&\r\n      ssmRect.bottom > 0 &&\r\n      ssmRect.left < window.innerWidth &&\r\n      ssmRect.right > 0\r\n    );\r\n  }\r\n\r\n  \/\/ Limpia claves hb_* y amzn*\r\n  function ssmClearHBAndAmznKeys(slot) {\r\n    const keys = slot.getTargetingKeys();\r\n    keys.forEach(key => {\r\n      if (key.startsWith(\"hb_\") || key.startsWith(\"amzn\")) {\r\n        slot.clearTargeting(key);\r\n      }\r\n    });\r\n  }\r\n\r\n  \/\/ Intervalo de comprobaci\u00f3n\r\n  setInterval(() => {\r\n    const ssmCurrentTime = Date.now();\r\n\r\n    for (const ssmSlotId in window.ssmAdSlotTime) {\r\n      const ssmLastRendered = window.ssmAdSlotTime[ssmSlotId];\r\n      const ssmLastLineItem = window.ssmAdSlotLineItem[ssmSlotId]; \/\/ recuperamos el lineItemId\r\n      const ssmDiffSeconds = (ssmCurrentTime - ssmLastRendered) \/ 1000;\r\n\r\n      if (ssmDiffSeconds >= ssmIntervalSeconds) {\r\n        const ssmElement = document.getElementById(ssmSlotId);\r\n        if (ssmElement && ssmIsInViewport(ssmElement)) {\r\n          const ssmSlot = googletag.pubads().getSlots().find(\r\n            s => s.getSlotElementId() === ssmSlotId\r\n          );\r\n\r\n          \/\/ \u2705 SOLO refresca si el \u00faltimo lineItemId fue 7002356118\r\n          if (ssmSlot && ssmLastLineItem === 7050801247) {\r\n            if (ssmSlot.getAdUnitPath().indexOf(\"1x1\") === -1) {\r\n              googletag.cmd.push(() => {\r\n                let ssmLastRefreshDate = new Date(ssmLastRendered).toLocaleTimeString(); \r\n                let ssmNewRefreshDate = new Date(ssmCurrentTime).toLocaleTimeString(); \r\n\r\n                \/\/ \ud83d\udd04 Limpia las claves hb_* y amzn* antes de refrescar\r\n                ssmClearHBAndAmznKeys(ssmSlot);\r\n\r\n                ssmSlot.setTargeting(\"up_recovery\", \"true\");\r\n                googletag.pubads().refresh([ssmSlot]);\r\n                ssmSmartTag.log(\"[SSM BOOST]=>\", ssmSlotId, 'last Refresh', ssmLastRefreshDate, 'new refresh date', ssmNewRefreshDate, ' each ', ssmDiffSeconds, \"secs\");\r\n              });\r\n              window.ssmAdSlotTime[ssmSlotId] = ssmCurrentTime;\r\n            }\r\n          }\r\n        }\r\n      }\r\n    }\r\n  }, ssmRefreshThresholdSeconds * 1000);\r\n\r\n})();*\/","has_schain":true,